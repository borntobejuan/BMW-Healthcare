        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0, "max": 7000,
          "unit": "rpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 5000 },
              { "color": "red",    "value": 6500 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "P1B275B51259D9601" },
        "query": "from(bucket: \"e87\")\n  |> range(start: -30s)\n  |> filter(fn: (r) => r._measurement == \"engine\" and r._field == \"rpm\")\n  |> last()",
        "refId": "A"
