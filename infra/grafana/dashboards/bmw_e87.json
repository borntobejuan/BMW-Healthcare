{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "BMW E87 120i — Live CAN Bus Telemetry",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "id": 1,
      "title": "RPM",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0, "max": 7000,
          "unit": "rpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0    },
              { "color": "yellow", "value": 5000 },
              { "color": "red",    "value": 6500 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
        "query": "from(bucket: \"e87\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r._measurement == \"engine\" and r._field == \"rpm\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "id": 2,
      "title": "Velocidad",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0, "max": 260,
          "unit": "velocitykmh",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 120 },
              { "color": "red",    "value": 200 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
        "query": "from(bucket: \"e87\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r._measurement == \"vehicle\" and r._field == \"speed_kmh\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "id": 3,
      "title": "Temperatura Refrigerante",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": -40, "max": 150,
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": -40 },
              { "color": "green",  "value": 70  },
              { "color": "yellow", "value": 100 },
              { "color": "red",    "value": 115 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
        "query": "from(bucket: \"e87\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r._measurement == \"temperatures\" and r._field == \"coolant_temp_c\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "id": 4,
      "title": "Voltaje Batería",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "volt",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 11.5 },
              { "color": "green",  "value": 13.0 },
              { "color": "yellow", "value": 15.0 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
        "query": "from(bucket: \"e87\")\n  |> range(start: -10s)\n  |> filter(fn: (r) => r._measurement == \"electrical\" and r._field == \"battery_voltage_v\")\n  |> last()",
        "refId": "A"
      }]
    },

    {
      "id": 5,
      "title": "RPM — Histórico",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "rpm",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          }
        }
      },
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
        "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"engine\" and r._field == \"rpm\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
        "refId": "A"
      }]
    },

    {
      "id": 6,
      "title": "Velocidad + Acelerador — Histórico",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "speed_kmh" },
            "properties": [{ "id": "unit", "value": "velocitykmh" }]
          },
          {
            "matcher": { "id": "byName", "options": "throttle_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
          "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"vehicle\" and r._field == \"speed_kmh\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
          "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"engine\" and r._field == \"throttle_pct\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "B"
        }
      ]
    },

    {
      "id": 7,
      "title": "Temperaturas — Histórico",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": true }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
          "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"temperatures\" and r._field == \"coolant_temp_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
          "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"temperatures\" and r._field == \"oil_temp_c\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "B"
        }
      ]
    },

    {
      "id": 8,
      "title": "Velocidades de Rueda",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "custom": { "lineWidth": 1, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_BMW}" },
          "query": "from(bucket: \"e87\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"wheel_speeds\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")",
          "refId": "A"
        }
      ]
    }

  ],

  "refresh": "1s",
  "schemaVersion": 38,
  "tags": ["bmw", "e87", "can"],
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BMW E87 120i — Live Telemetry",
  "uid": "bmw-e87-live",
  "version": 1
}
